# Neon PostgreSQL connection string (required)
# Get this from your Neon dashboard: project → Connection Details → Connection string
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require

# LLM Gateway API key (required for AI features: auto-naming, quality checks)
LLM_GATEWAY_KEY=llmgw_your_key_here

# Model configuration (optional — defaults shown below)
# MODEL_DEFAULT=claude-opus-4-7
# MODEL_FAST=claude-haiku-4-5-20251001
# MODEL_STRONG=claude-opus-4-7
# MODEL_QUALITY=claude-sonnet-4-6
# MODEL_OPTIONS=claude-opus-4-7:Opus,claude-sonnet-4-6:Sonnet

# Node environment
NODE_ENV=development
