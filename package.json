{
  "name": "mission-control",
  "version": "1.0.0",
  "description": "Web-based dashboard for monitoring and interacting with Claude Code sessions",
  "main": "server/index.js",
  "scripts": {
    "prestart": "bash setup.sh",
    "predev": "bash setup.sh",
    "start": "node server/index.js",
    "dev": "concurrently \"node server/index.js\" \"cd client && npx vite\"",
    "build": "cd client && npx vite build",
    "server": "node server/index.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "chokidar": "^3.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "multer": "^2.1.1",
    "tree-kill": "^1.2.2",
    "undici": "^7.24.6",
    "uuid": "^10.0.0",
    "web-push": "^3.6.7",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "jsdom": "^29.0.2",
    "vitest": "^4.1.3"
  }
}
